# Retraction Contagion Graph — environment configuration
# Copy this file to `.env` and adjust values as needed.
# All variables are optional; commented values show the built-in default
# used by shared/config.py:Settings when a variable is unset.

# --- External API endpoints ---
# CROSSREF_MAILTO=demo@example.com
# CROSSREF_BASE_URL=https://api.crossref.org
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
# RETRACTION_WATCH_CSV_URL=https://gitlab.com/crossref/retraction-watch-data/-/raw/main/retraction_watch.csv

# --- HTTP resilience ---
# REQUEST_TIMEOUT_SECONDS=10.0
# MAX_RETRIES=3
# RETRY_BACKOFF_BASE_SECONDS=0.5

# --- Ingestion scope ---
# SEED_RETRACTION_COUNT=8
# MIN_CITATION_COUNT=10
# MAX_CITATION_COUNT=50

# --- Logging ---
# LOG_LEVEL=INFO
