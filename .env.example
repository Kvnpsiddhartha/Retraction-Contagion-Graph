# Retraction Contagion Graph — environment configuration
# Copy this file to `.env` and adjust values as needed.
# All variables are optional; commented values show the built-in default
# used by shared/config.py:Settings when a variable is unset.

# --- Cognee / LLM configuration -------------------------------------------
# Cognee uses an LLM to build its knowledge graph and to answer recall()
# queries. Set one of the following depending on which provider you want:
#
# Option A — OpenAI (recommended for hackathon, easiest setup):
# LLM_API_KEY=sk-...
# OPENAI_API_KEY=sk-...           # Cognee also checks this env var directly
# LLM_MODEL=gpt-4o-mini           # or gpt-3.5-turbo for lower cost
#
# Option B — Other providers (see Cognee docs for full list):
# LLM_PROVIDER=anthropic
# LLM_API_KEY=...
#
# Without an LLM key:
#   * The seed script still works and stages all demo edges correctly.
#   * /api/graph, /api/improve, and /api/forget all work (local edge store).
#   * /api/recall returns empty results (degrades gracefully, logs a warning).

# --- External API endpoints ---
# CROSSREF_MAILTO=demo@example.com
# CROSSREF_BASE_URL=https://api.crossref.org
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
# RETRACTION_WATCH_CSV_URL=https://gitlab.com/crossref/retraction-watch-data/-/raw/main/retraction_watch.csv

# --- HTTP resilience ---
# REQUEST_TIMEOUT_SECONDS=10.0
# MAX_RETRIES=3
# RETRY_BACKOFF_BASE_SECONDS=0.5

# --- Ingestion scope ---
# SEED_RETRACTION_COUNT=8
# MIN_CITATION_COUNT=10
# MAX_CITATION_COUNT=50

# --- Logging ---
# LOG_LEVEL=INFO
